# 環境変数テンプレート
# このファイルをコピーして.env.localを作成してください
# cp .env.example .env.local

# アプリケーション名
NEXT_PUBLIC_APP_NAME=your-app-name

# 開発環境
NODE_ENV=development

# APIエンドポイント（必要に応じて設定）
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ========================================
# データベース設定（Supabase または Neon のどちらかを選択）
# ========================================
# このテンプレートは特定のDBに依存しません。プロジェクトで使うDBを
# 1つ選び、該当ブロックのコメントを外して設定してください。
# 判断軸: クライアントがDBに直接到達するか（→ Supabase）/
#         バックエンドが必ず仲介するか（→ Neon）。詳細は SPECIFICATION.md §12.15.9.10

# --- 選択肢A: Supabase（Data API・認証・RLS が一体。フロント完結型に強い） ---
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# 注意: public スキーマの新規テーブルは明示GRANTが必要（2026-05-30〜・SPECIFICATION.md §12.15.9）

# --- 選択肢B: Neon（素のPostgres。バックエンド仲介・serverless接続） ---
# 接続文字列はサーバー専用。NEXT_PUBLIC_ を付けない（クライアントに漏らさない）
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# 注意: Auth SDK/API/拡張は破壊的変更が多い。実装前に現行仕様を確認（SPECIFICATION.md §12.15.9.11）

# その他の環境変数
# 必要に応じてプロジェクト固有の環境変数を追加してください